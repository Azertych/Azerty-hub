-- SILENT AIM ENHANCEMENT ENGINE BACKGROUND CORE
-- ====================================================================
task.spawn(function()
    local success, err = pcall(function()
        local phem5 = require(LocalPlayer.PlayerScripts:WaitForChild("Controllers"):WaitForChild("Combat"):WaitForChild("KnifeController"))

        local function getClosestPlayerToCursor()
            local targetPlayer = nil
            local maxDistance = getgenv().KnifeConfig.FOV
            local centerScreen = Camera.ViewportSize / 2
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                    local targetPart = player.Character:FindFirstChild(getgenv().KnifeConfig.HitPart)
                    if targetPart then
                        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                        if onScreen then
                            local mouseDistance = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
                            if mouseDistance < maxDistance then
                                targetPlayer = player
                                maxDistance = mouseDistance
                            end
                        end
                    end
                end
            end
            return targetPlayer
        end

        local oldGetThrowDirection = phem5._GetThrowDirection
        phem5._GetThrowDirection = function(self, originPart)
            if getgenv().KnifeConfig.Enabled then
                if math.random(1, 100) <= getgenv().KnifeConfig.HitChance then
                    local targetPlayer = getClosestPlayerToCursor()
                    if targetPlayer and targetPlayer.Character then
                        local targetPart = targetPlayer.Character:FindFirstChild(getgenv().KnifeConfig.HitPart)
                        if targetPart then
                            return (targetPart.Position - originPart.Position).Unit
                        end
                    end
                end
            end
            return oldGetThrowDirection(self, originPart)
        end
    end)
    if not success then
        warn("Azerty Hub Engine Core Hook Failure: " .. tostring(err))
    end
end)

